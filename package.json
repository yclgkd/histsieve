{
  "name": "histsieve",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension: keyword-based and scheduled browser history cleanup.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:ci": "biome ci .",
    "assets:store": "node scripts/generate-store-assets.mjs",
    "build:release": "node scripts/release.mjs"
  },
  "pnpm": {
    "overrides": {
      "rollup@<2.80.0": "2.80.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.5",
    "vite": "^6.4.2",
    "vitest": "^4.1.6"
  }
}
